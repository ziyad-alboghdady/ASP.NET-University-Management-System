@model demoEFapp.Models.Teacher

@{
    ViewData["Title"] = "Create Teacher";
}

<div class="create-page">
    <div class="create-card">
        <div class="create-header">
            <h1>Create Teacher</h1>
            <p>Fill in the teacher information below</p>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="TeacherName" class="control-label"></label>
                <input asp-for="TeacherName" class="form-control" placeholder="Enter teacher name" />
                <span asp-validation-for="TeacherName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TeacherAge" class="control-label"></label>
                <input asp-for="TeacherAge" class="form-control" placeholder="Enter teacher age" />
                <span asp-validation-for="TeacherAge" class="text-danger"></span>
            </div>

            <div class="btn-group-custom">
                <input type="submit" value="Create" class="btn-custom btn-create" />
                <a asp-action="Index" class="btn-custom btn-home">Back to List</a>
            </div>
        </form>
    </div>
</div>
