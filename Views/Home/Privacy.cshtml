@{
    ViewData["Title"] = "About Project";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <h1 class="fw-bold mb-3">About This Project</h1>
                <p class="text-muted mb-4">
                    This is a simple university management system built with ASP.NET MVC.
                    The project helps manage students, teachers, courses, rooms, and course registrations.
                </p>

                <h4 class="fw-bold mb-3">Main Features</h4>
                <ul class="text-muted">
                    <li>Manage students with create, edit, and delete operations</li>
                    <li>Upload student profile photos</li>
                    <li>Register students in courses</li>
                    <li>Display registered courses for each student</li>
                    <li>Manage teachers, rooms, and courses</li>
                    <li>Clean and responsive user interface using Bootstrap</li>
                </ul>

                <h4 class="fw-bold mt-4 mb-3">Technologies Used</h4>
                <ul class="text-muted">
                    <li>ASP.NET Core MVC</li>
                    <li>Entity Framework Core</li>
                    <li>PostgreSQL</li>
                    <li>Bootstrap</li>
                    <li>C#</li>
                </ul>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">Back to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>