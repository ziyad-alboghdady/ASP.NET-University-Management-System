@model List<demoEFapp.ViewModels.UserRoleVM>

@{
    ViewData["Title"] = "Users Management";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div>
                        <h2 class="fw-bold mb-1">Users Management</h2>
                        <p class="text-muted mb-0">View all users and manage their roles.</p>
                    </div>

                 
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>User Name</th>
                                <th>Email</th>
                                <th>Current Role</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                @foreach (var item in Model)
                                {
                                            <tr>
                                                <td>@item.UserName</td>
                                                <td>@item.Email</td>
                                                <td>
                                                    <span class="badge bg-secondary">@item.CurrentRole</span>
                                                </td>
                                                <td>
                                                    <a asp-controller="Admin"
                                                       asp-action="EditRole"
                                                       asp-route-userId="@item.UserId"
                                                       class="btn btn-sm btn-primary">
                                                        Manage Role
                                                    </a>
                                                </td>
                                            </tr>
                                }
                            }
                            else
                            {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            No users found.
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>