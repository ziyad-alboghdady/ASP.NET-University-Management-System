@{
    ViewData["Title"] = "Edit User Role";
    var roles = ViewBag.AllRoles as List<string>;
    var currentRoles = ViewBag.UserRoles as IList<string>;
}

<h2 class="mb-4">Edit Role for @ViewBag.UserName</h2>

<form asp-action="EditRole" method="post">

    <input type="hidden" name="userId" value="@ViewBag.UserId" />

    <div class="mb-3">
        <label class="form-label">Select Role</label>

        <select name="roleName" class="form-control">

            @foreach (var role in roles)
            {
                if (currentRoles.Contains(role))
                {
                    <option selected value="@role">@role</option>
                }
                else
                {
                    <option value="@role">@role</option>
                }
            }

        </select>
    </div>

    <button class="btn btn-primary">Save</button>

    <a asp-action="Users" class="btn btn-secondary">
        Cancel
    </a>

</form>