@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">

    <div class="mb-4">
        <h2 class="fw-bold">Admin Dashboard</h2>
        <p class="text-muted">
            Manage system users and data from this panel.
        </p>
    </div>

    <div class="row g-4">

        <!-- Users -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center">

                    <h5 class="fw-semibold mb-2">Users</h5>

                    <p class="text-muted small">
                        Manage user accounts and roles.
                    </p>

                    <a asp-controller="Admin"
                       asp-action="Users"
                       class="btn btn-primary btn-sm">
                        Manage Users
                    </a>

                </div>
            </div>
        </div>

        <!-- Students -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center">

                    <h5 class="fw-semibold mb-2">Students</h5>

                    <p class="text-muted small">
                        View, edit and manage students.
                    </p>

                    <a asp-controller="Student"
                       asp-action="Index"
                       class="btn btn-outline-primary btn-sm">
                        Open Students
                    </a>

                </div>
            </div>
        </div>

        <!-- Teachers -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center">

                    <h5 class="fw-semibold mb-2">Teachers</h5>

                    <p class="text-muted small">
                        Manage teachers information.
                    </p>

                    <a asp-controller="Teacher"
                       asp-action="Index"
                       class="btn btn-outline-primary btn-sm">
                        Open Teachers
                    </a>

                </div>
            </div>
        </div>

        <!-- Courses -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center">

                    <h5 class="fw-semibold mb-2">Courses</h5>

                    <p class="text-muted small">
                        Manage courses and assignments.
                    </p>

                    <a asp-controller="Course"
                       asp-action="Index"
                       class="btn btn-outline-primary btn-sm">
                        Open Courses
                    </a>

                </div>
            </div>
        </div>

        <!-- Rooms -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center">

                    <h5 class="fw-semibold mb-2">Rooms</h5>

                    <p class="text-muted small">
                        Manage available rooms.
                    </p>

                    <a asp-controller="Room"
                       asp-action="Index"
                       class="btn btn-outline-primary btn-sm">
                        Open Rooms
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>