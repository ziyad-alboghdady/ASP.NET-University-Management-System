@model demoEFapp.ViewModels.StudentIndexVM

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-1">Students</h2>
        <p class="text-muted mb-0">Manage students, edit their data, and register them in courses.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary px-4">+ Add Student</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Photo</th>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Courses</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Students != null && Model.Students.Count > 0)
                    {
                        @foreach (var item in Model.Students)
                        {
                            <tr>
                                <td>@item.StudentId</td>

                                <td>
                                    @if (!string.IsNullOrEmpty(item.PhotoName))
                                    {
                                        <img src="~/StudentPictures/@item.PhotoName"
                                             alt="Student Photo"
                                             style="width:60px;height:60px;object-fit:cover;border-radius:50%;border:2px solid #e5e7eb;" />
                                    }
                                    else
                                    {
                                        <div style="width:60px;height:60px;border-radius:50%;background:#e5e7eb;display:flex;align-items:center;justify-content:center;font-weight:bold;color:#6b7280;">
                                            N/A
                                        </div>
                                    }
                                </td>

                                <td class="fw-semibold">@item.StudentName</td>
                                <td>@item.StudentAge</td>

                                <td>
                                    @if (item.StudentCourses != null && item.StudentCourses.Count > 0)
                                    {
                                        @foreach (var sc in item.StudentCourses)
                                        {
                                            <span class="badge bg-info text-dark me-1 mb-1">@sc.Course.CourseName</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No courses</span>
                                    }
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">

                                        <a asp-action="Edit"
                                           asp-route-id="@item.StudentId"
                                           class="btn btn-sm btn-warning text-white">
                                            Edit
                                        </a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete"
                                                  method="post"
                                                  style="display:inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this student?');">

                                                <input type="hidden"
                                                       name="StudentId"
                                                       value="@item.StudentId" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-danger">
                                                    Delete
                                                </button>
                                            </form>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                No students found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">

    <div class="text-muted">
        Page <strong>@Model.PageNumber</strong> of
        <strong>@Model.TotalPages</strong> |
        Total Students: <strong>@Model.TotalCount</strong>
    </div>

    <div class="d-flex gap-2">

        <a class="btn btn-outline-secondary btn-sm @(Model.HasPrevious ? "" : "disabled")"
           asp-action="Index"
           asp-route-pageNumber="@(Model.PageNumber - 1)"
           asp-route-pageSize="@Model.PageSize">
            Previous
        </a>

        <a class="btn btn-outline-secondary btn-sm @(Model.HasNext ? "" : "disabled")"
           asp-action="Index"
           asp-route-pageNumber="@(Model.PageNumber + 1)"
           asp-route-pageSize="@Model.PageSize">
            Next
        </a>

    </div>

</div>